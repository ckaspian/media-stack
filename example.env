# ============================================================================
# MEDIA STACK CONFIGURATION EXAMPLE
# ============================================================================
# Documentation: Rename this file to '.env' and update the values below
# before running 'docker compose up -d' for the first time.

# ============================================================================
# CORE SETTINGS
# ============================================================================

# Data root directory - All persistent data will be stored here
# Examples: /mnt/storage, /home/user/media-stack, ./data
DATA_ROOT=/path/to/your/data # <-- IMPORTANT: Update this to your media storage path

# User/Group IDs for file permissions (run 'id' command to find yours)
PUID=1000
PGID=1000

# Timezone - See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Stack name (used for container prefixes if needed)
STACK_NAME=media

# ============================================================================
# VPN CONFIGURATION (Gluetun)
# ============================================================================

# VPN Provider Settings (e.g., protonvpn, mullvad, nordvpn)
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard

# WireGuard Keys (REPLACE WITH YOUR OWN!)
# Generate new keys from your VPN provider's dashboard
TORRENT_WIREGUARD_PRIVATE_KEY="REPLACE_WITH_YOUR_TORRENT_WIREGUARD_KEY" # <-- IMPORTANT
SLSKD_WIREGUARD_PRIVATE_KEY="REPLACE_WITH_YOUR_SLSKD_WIREGUARD_KEY"   # <-- IMPORTANT

# VPN Server Location (e.g., "United States", Canada, "Switzerland")
SERVER_COUNTRIES="United States"

# Port Forwarding Configuration
PORT_FORWARD_ONLY=on
VPN_PORT_FORWARDING=on

# ============================================================================
# SERVICE PORTS
# ============================================================================
# These are the default ports. You can change them if they conflict with
# other services running on your host machine.

# Download Clients (Behind VPN)
QBITTORRENT_WEBUI_PORT=8080
SLSKD_PORT=8585

# Media Management (*arr stack)
SONARR_PORT=8181
RADARR_PORT=8282
LIDARR_PORT=8383
READARR_PORT=8484
PROWLARR_PORT=9696
PICARD_PORT=8586

# Media Servers
NAVIDROME_PORT=8686
JELLYFIN_PORT=8096
JELLYFIN_DISCOVERY_PORT=7359

# VPN Management
GLUETUN_TORRENTS_API_PORT=8000
GLUETUN_SLSKD_API_PORT=8001

# ============================================================================
# VERSION TAGS
# ============================================================================

# Use 'latest' for stable or specify version tags if needed
READARR_VERSION=0.4.19-nightly
LIDARR_VERSION=2.14.1-nightly
PROWLARR_VERSION=2.1.0-develop
PICARD_VERSION=2.13.3

# ============================================================================
# REMOTE ACCESS (Cloudflare Tunnel)
# ============================================================================

# Create a tunnel in the Cloudflare Zero Trust dashboard and paste the token here
CLOUDFLARE_TUNNEL_TOKEN="REPLACE_WITH_YOUR_CLOUDFLARE_TUNNEL_TOKEN" # <-- IMPORTANT

# ============================================================================
# ADVANCED SETTINGS (Optional)
# ============================================================================

# Resource Limits (uncomment to enable)
# ENABLE_RESOURCE_LIMITS=true

# Backup Configuration
# BACKUP_ENABLED=false
# BACKUP_SCHEDULE="0 3 * * *"  # Daily at 3 AM
# BACKUP_RETENTION_DAYS=7
# BACKUP_PATH=${DATA_ROOT}/backups

# Monitoring
# ENABLE_MONITORING=false
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000

# ============================================================================
# NETWORK CONFIGURATION (Optional)
# ============================================================================

# Docker network settings (advanced users)
# NETWORK_SUBNET_VPN=172.20.0.0/24
# NETWORK_SUBNET_MEDIA=172.21.0.0/24
# NETWORK_SUBNET_FRONTEND=172.22.0.0/24

# ============================================================================
# SECURITY SETTINGS (Optional)
# ============================================================================

# Enable automatic updates via Watchtower
# WATCHTOWER_ENABLED=false
# WATCHTOWER_SCHEDULE="0 0 4 * * *"  # Daily at 4 AM

# Firewall rules for VPN
# FIREWALL_OUTBOUND_SUBNETS=""
# FIREWALL_DEBUG=false
